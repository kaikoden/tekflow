    /* ── HOW IT WORKS ──────────────────────── */
    .how-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0; margin-top: 48px; position: relative;
    }
    .how-step {
      padding: 28px 24px; position: relative;
