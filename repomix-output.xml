    .oss-cta h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 16px; }
    .oss-cta p { font-size: 1.05rem; color: var(--text-muted); max-width: 540px; margin: 0 auto 40px; line-height: 1.7; }
    .oss-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .contrib-grid {
      display: flex; flex-wrap: wrap; gap: 10px;
      justify-content: center; margin-top: 40px;
    }
    .contrib-chip {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 100px; padding: 7px 16px;
      font-size: 13px; font-weight: 600; color: var(--text-muted);
    }

    /* ── FOOTER ────────────────────────────── */
    footer {
      text-align: center; padding: 40px 24px;
      color: var(--text-muted); font-size: 13px;
    }
    footer a { color: var(--accent); text-decoration: none; }
    footer a:hover { text-decoration: underline; }
    .footer-links { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; margin-bottom: 16px; }

    /* ── MOBILE ────────────────────────────── */
    @media (max-width: 768px) {
      nav { padding: 14px 20px; }
