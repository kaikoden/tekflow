      position: absolute; border-radius: 50%;
      filter: blur(80px); opacity: .35;
    }
    .hero-blob-1 { width: 500px; height: 500px; background: var(--accent); top: -100px; left: -100px; }
    .hero-blob-2 { width: 400px; height: 400px; background: var(--accent2); bottom: -80px; right: -80px; }
    .hero-blob-3 { width: 300px; height: 300px; background: var(--green); top: 40%; left: 40%; }
