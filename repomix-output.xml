    .oss-cta {
      text-align: center; padding: 80px 24px;
      background: linear-gradient(135deg, rgba(108,99,255,.08), rgba(0,212,255,.08));
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      margin: 80px 0 0;
